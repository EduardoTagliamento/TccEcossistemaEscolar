# Environment Variables - Ecossistema Escolar

# 🔹 Node Environment
NODE_ENV=development

# 🔹 Server Configuration
PORT=3000

# 🔹 MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=tccecossistemaescolar
DB_PORT=3306

# 🔹 JWT Configuration (para futuro módulo de autenticação)
# JWT_SECRET=seu_secret_key_aqui
# JWT_EXPIRES_IN=24h

# 🔹 Upload Configuration
# MAX_FILE_SIZE=10mb

# 🔹 CORS Configuration
# CORS_ORIGIN=http://localhost:3000

# 🔹 Frontend URL (para links em e-mails)
FRONTEND_URL=http://localhost:3000

# 🔹 Logging Level
# LOG_LEVEL=debug

# 🔹 ============================================
# 🔐 CHAVES DE API EXTERNAS (Serviços de Terceiros)
# 🔹 ============================================

# OpenAI / Azure OpenAI (para recursos de IA)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_ORG_ID=org-xxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_OPENAI_ENDPOINT=https://seu-recurso.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4

# Google APIs (Google Classroom, Drive, etc.)
# GOOGLE_CLIENT_ID=xxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_API_KEY=AIzaSyXxXxXxXxXxXxXxXxXxXxXxXxXxXxXxXxX

# Email Service (Resend - https://resend.com)
# Obtenha sua chave em: https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
TEST_EMAIL_TO=bauaecossistemaescolar@gmail.com

# Storage (Cloudflare R2 - compatível com S3)
# Account API Token / User API Token: https://dash.cloudflare.com/ → R2 → Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ecossistema-escolar-uploads
# URL pública do bucket (Public Development URL "pub-xxxx.r2.dev" ou domínio customizado)
R2_PUBLIC_URL=

# Payment Gateway (Stripe, PagSeguro, etc.)
# STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PAGSEGURO_EMAIL=seu@email.com
# PAGSEGURO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SMS Service (Twilio, etc.)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+5511999999999

# Analytics
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# MIXPANEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 🔹 ============================================
# 💡 IMPORTANTE: 
# - Nunca commite o arquivo .env com valores reais
# - Use este .env.example como template
# - Crie seu .env local: cp .env.example .env
# - Adicione suas chaves reais no .env
# 🔹 ============================================
