# Environment Variables - Ecossistema Escolar

# 🔹 Node Environment
NODE_ENV=development

# 🔹 Server Configuration
PORT=3000

# 🔹 MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=tccecossistemaescolar
DB_PORT=3306

# 🔹 Email Service (Resend)
# Obtenha sua chave em: https://resend.com/api-keys
RESEND_API_KEY=insira chave aqui
EMAIL_FROM=onboarding@resend.dev

# 🔹 Frontend URL (para links em e-mails)
FRONTEND_URL=http://localhost:3000
